{
    "name": "calibreviewer",
    "version": "3.0.2",
    "description": "Modern IPTV Player",
    "license": "GPL-3.0-only",
    "main": "server/index.js",
    "scripts": {
        "start": "node server/index.js",
        "dev": "node --watch server/index.js",
        "desktop": "electron electron/main.js",
        "desktop:dev": "cross-env NODE_ENV=development electron electron/main.js",
        "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
        "postinstall": "electron-builder install-app-deps",
        "dist": "electron-builder",
        "dist:win": "electron-builder --win --x64"
    },
    "dependencies": {
        "@ffprobe-installer/ffprobe": "^2.1.2",
        "bcryptjs": "^3.0.3",
        "better-sqlite3": "^12.5.0",
        "dotenv": "^17.2.3",
        "express": "^4.18.2",
        "express-session": "^1.18.2",
        "jsonwebtoken": "^9.0.3",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "passport-openidconnect": "^0.1.2",
        "sax": "^1.4.3",
        "xml2js": "^0.6.2"
    },
    "devDependencies": {
        "cross-env": "^7.0.3",
        "electron": "^32.2.0",
        "electron-rebuild": "^3.2.9",
        "electron-builder": "^24.13.3"
    },
    "optionalDependencies": {
        "ffmpeg-static": "^5.3.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "build": {
        "appId": "com.calibreviewer.desktop",
        "productName": "CalibreViewer",
        "extraMetadata": {
            "main": "electron/main.js"
        },
        "directories": {
            "output": "release"
        },
        "files": [
            "electron/**/*",
            "public/**/*",
            "server/**/*",
            "package.json"
        ],
        "asarUnpack": [
            "**/*.node",
            "**/ffmpeg-static/**",
            "**/@ffprobe-installer/**"
        ],
        "win": {
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "deleteAppDataOnUninstall": false
        }
    }
}